<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
        <%= title %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
    <!-- Favicons -->
    <link href="/assets/img/favicon.png" rel="icon">
    <link href="/assets/img/apple-touch-icon.png" rel="apple-touch-icon">
    <!-- Google Fonts -->
    <link
        href="https://fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i|Roboto:300,300i,400,400i,500,500i,600,600i,700,700i|Poppins:300,300i,400,400i,500,500i,600,600i,700,700i"
        rel="stylesheet">
    <!-- Crud Stylesheet -->
    <link rel="stylesheet" href="/assets/css/crud.css">
</head>

<body>

    <div class="container">
        <div class="row mt-5">
            <h2 class="lead fw-normal fs-3 text-capitalize">Register User</h2>
            <form action="/create/register" id="myForm" method="post" enctype="multipart/form-data">
                <div class="row p-3 bg-light-400">
                    <div class="my-3">
                        <label for="name" class="form-label fs-5">Name</label>
                        <input type="text" class="form-control field-control" placeholder="Enter Your Name" name="name" required>
                    </div>
                    <div class="my-3">
                        <label for="email" class="form-label fs-5">Email</label>
                        <input type="email" class="form-control field-control" placeholder="Enter Your Email" name="email" required>
                    </div>
                    <div class="my-3">
                        <label for="phone" class="form-label fs-5">Phone</label>
                        <input type="tel" class="form-control field-control" placeholder="Enter Your Phone No." name="phone" required>
                    </div>
                    <div class="my-3">
                        <label for="password" class="form-label fs-5">Password</label>
                        <input type="password" class="form-control field-control" placeholder="Enter Your Password" name="password" required>
                    </div>

                    <div class="my-3">
                        <label for="image" class="form-label fs-5">User Image</label>
                        <input type="file" class="form-control field-control" name="image" required>
                    </div>
                    <div class="row justify-content-center">
                        <div class="col-3 my-3">
                            <button type="submit" class="btn btn-lg btn-primary w-100">Register User</button>
                        </div>
                        <hr class="mt-3">
                        <h5 class="text-black text-center fw-normal fs-5">Already have an account? Please <a
                                class="text-primary text-decoration-none" href="/login/view">Login</a></h5>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>